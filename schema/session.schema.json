{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ghost Hours Session Entry",
  "description": "Schema for Ghost Hours log entries (v1.0). Copyright 2026 Raven Systems Inc.",
  "oneOf": [
    { "$ref": "#/$defs/session" },
    { "$ref": "#/$defs/retrospection" },
    { "$ref": "#/$defs/amendment" }
  ],
  "$defs": {
    "session": {
      "type": "object",
      "required": ["session_id", "ts", "date", "type", "entry_class", "human_mins", "gh_mins", "desc", "source", "schema_version"],
      "properties": {
        "session_id": { "type": "string", "format": "uuid" },
        "ts": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "type": { "type": "string", "enum": ["speed", "unlock", "methodology-note"] },
        "entry_class": {
          "type": "string",
          "enum": ["human", "scheduler", "artifact"],
          "description": "Who produced the entry: a live human+agent session, an automated scheduler agent, or a machine-generated artifact."
        },
        "human_mins": { "type": "integer", "minimum": 0 },
        "gh_mins": { "type": "integer", "minimum": 0 },
        "desc": { "type": "string", "maxLength": 280 },
        "source": { "type": "string" },
        "schema_version": { "type": "string" },
        "subtype": { "type": "string", "enum": ["restoration", "bypass", "augmentation"] },
        "gh_confidence": { "type": "string", "enum": ["low", "medium", "high", "review"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "backlog_months": { "type": "number", "minimum": 0 },
        "backlog_weight": { "type": "number", "minimum": 0 },
        "fwc": { "type": "integer", "minimum": 1, "maximum": 10 },
        "fwc_source": {
          "type": "string",
          "enum": ["operator", "agent-blind"],
          "description": "Who supplied the fwc score: the user (operator) or the agent estimating blind on the user's behalf."
        },
        "fwc_eom": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "The agent's blind FW-C estimate, computed silently at logging time and revealed only during retro. Field name retained for dataset compatibility with pre-1.0 logs; read it as fwc_agent."
        },
        "note": { "type": "string", "maxLength": 1000 },
        "project": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "unlock" } }, "required": ["type"] },
          "then": { "required": ["subtype"] }
        },
        {
          "if": { "properties": { "type": { "enum": ["speed", "methodology-note"] } }, "required": ["type"] },
          "then": { "properties": { "subtype": false } }
        }
      ],
      "additionalProperties": false
    },
    "retrospection": {
      "type": "object",
      "required": ["ts", "type", "session_id", "fwr", "fwr_source", "source", "schema_version"],
      "properties": {
        "ts": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "type": { "type": "string", "const": "retrospection" },
        "session_id": { "type": "string", "format": "uuid" },
        "fwr": { "type": "integer", "minimum": 1, "maximum": 10 },
        "fwr_source": {
          "type": "string",
          "enum": ["field-report", "manual", "migrated"],
          "description": "How the FW-R score was collected."
        },
        "fwr_note": {
          "type": "string",
          "maxLength": 1000,
          "description": "User's verbatim reflection at retrospection time."
        },
        "source": { "type": "string" },
        "schema_version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "amendment": {
      "type": "object",
      "required": ["ts", "type", "session_id", "changes", "source", "schema_version"],
      "properties": {
        "ts": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "const": "amendment" },
        "session_id": { "type": "string", "format": "uuid" },
        "changes": { "type": "object" },
        "source": { "type": "string" },
        "schema_version": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
