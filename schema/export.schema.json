{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ghost Hours Export",
  "description": "Schema for de-identified Ghost Hours share exports (v1.0). Retrospection scores are folded into their session rows at export time; no session_id ever leaves the machine (session IDs are a re-identification vector). Copyright 2026 Raven Systems Inc.",
  "type": "object",
  "required": ["dataset", "schema_version", "participant_id", "export_date", "session_count", "entries"],
  "properties": {
    "dataset": { "type": "string", "const": "The Ghost Hours Open Dataset 2026" },
    "schema_version": { "type": "string" },
    "participant_id": { "type": "string" },
    "export_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "session_count": { "type": "integer", "minimum": 0 },
    "retrospection_count": { "type": "integer", "minimum": 0 },
    "x_suppressed_tags": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of exported entries that had a tags field stripped during de-identification."
    },
    "x_suppressed_projects": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of exported entries that had a project field stripped during de-identification."
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["participant_id", "date", "type"],
        "properties": {
          "participant_id": { "type": "string" },
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "type": { "type": "string", "enum": ["speed", "unlock", "methodology-note", "retrospection"] },
          "entry_class": { "type": "string", "enum": ["human", "scheduler", "artifact"] },
          "subtype": { "type": "string", "enum": ["restoration", "bypass", "augmentation"] },
          "human_mins": { "type": "integer", "minimum": 0 },
          "gh_mins": { "type": "integer", "minimum": 0 },
          "gh_confidence": { "type": "string", "enum": ["low", "medium", "high", "review"] },
          "backlog_months": { "type": "number", "minimum": 0 },
          "backlog_weight": { "type": "number", "minimum": 0 },
          "fwc": { "type": "integer", "minimum": 1, "maximum": 10 },
          "fwc_source": { "type": "string", "enum": ["operator", "agent-blind"] },
          "fwc_eom": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "description": "The agent's blind FW-C estimate. Field name retained for dataset compatibility; read it as fwc_agent."
          },
          "fwr": { "type": "integer", "minimum": 1, "maximum": 10 },
          "fwr_source": { "type": "string", "enum": ["field-report", "manual", "migrated"] },
          "schema_version": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
